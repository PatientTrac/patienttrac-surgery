# PatientTracSurg — Required Environment Variables
# Set these in Netlify dashboard → Site settings → Environment variables
# Never commit real values to version control.

# ── Supabase (Vite app) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://mskormozwekezjmtcylv.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Organization identity ────────────────────────────────────────────────────
VITE_ORG_ID=00000000-0000-0000-0000-000000000001

# ── Deep-link back to the scheduling app ─────────────────────────────────────
VITE_SCHEDULING_URL=https://patienttracforge.com

# ── Shared Proposal Invoice (hosted by PatientTrac OR) ───────────────────────
VITE_PATIENTTRAC_OR_URL=https://patienttracor.com
VITE_SHARED_FN_BASE=https://patienttracor.com

# ── Supabase (Netlify Functions / legacy inject-env.sh) ────────────────────
SUPABASE_URL=https://mskormozwekezjmtcylv.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ── Anthropic ───────────────────────────────────────────────────────────────
# Server-side only — NEVER expose in client HTML or commit to git.
# Requires a BAA with Anthropic before PHI can flow through AI functions.
# Used exclusively by netlify/functions/ai-*.js and edge functions.
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (email notifications) ─────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
NOTIFY_FROM_EMAIL=noreply@patienttrac.com
RESEND_API_KEY=re_...
