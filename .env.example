# PatientTracSurg — Required Environment Variables
# Set these in Netlify dashboard → Site settings → Environment variables
# Never commit real values to version control.

# ── Supabase ────────────────────────────────────────────────────────────────
# Anon (public) key — injected into HTML files at build time by inject-env.sh
SUPABASE_ANON_KEY=eyJhbGci...

# Full project URL (used by Netlify Functions for token validation)
SUPABASE_URL=https://<project-ref>.supabase.co

# ── Anthropic ───────────────────────────────────────────────────────────────
# Server-side only — NEVER expose in client HTML or commit to git.
# Requires a BAA with Anthropic before PHI can flow through AI functions.
# Used exclusively by netlify/functions/ai-*.js
ANTHROPIC_API_KEY=sk-ant-...
